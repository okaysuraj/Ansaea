# Ansaea Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.

# Database: Neon Cloud Postgres (using asyncpg driver for async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://<USER>:<PASSWORD>@<NEON_HOST>/neondb?sslmode=require

# Security (Generate a secure random key for production)
SECRET_KEY=SERENE_ANSAEA_SECRET_KEY_MAXIMUM_SECURITY

# AI Service (Gemini API Key)
GEMINI_API_KEY=your_gemini_api_key_here
